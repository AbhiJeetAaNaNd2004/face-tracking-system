# ======================================
# Face Tracking System - Docker Environment Configuration
# Copy this file to .env and update the values for your deployment
# ======================================

# Database Configuration
DB_PASSWORD=secure_database_password_change_me

# Security Configuration (CRITICAL: Change this in production!)
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars-please

# Server Configuration
WORKERS=2
LOG_LEVEL=info

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Camera Configuration
MAX_CAMERA_STREAMS=5

# Feature Flags
ENABLE_DOCS=true
DEBUG=false