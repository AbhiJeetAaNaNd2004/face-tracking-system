# ======================================
# Face Tracking System - Environment Configuration
# Copy this file to .env and update the values
# ======================================

# Security Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=face_tracking
DB_USER=postgres
DB_PASSWORD=your-database-password

# Alternative: Complete Database URL (use this OR the individual DB_* vars above)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/face_tracking

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# Camera Configuration
MAX_CAMERA_STREAMS=5
DEFAULT_CAMERA_RESOLUTION_WIDTH=1920
DEFAULT_CAMERA_RESOLUTION_HEIGHT=1080
DEFAULT_CAMERA_FPS=30

# Face Recognition Configuration
FACE_DETECTION_CONFIDENCE=0.7
FACE_RECOGNITION_THRESHOLD=0.6
EMBEDDING_MODEL_PATH=/path/to/your/face/model
GPU_DEVICE_ID=0

# File Storage Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Monitoring and Logging
ENABLE_STRUCTURED_LOGGING=true
LOG_FILE_PATH=./logs/app.log
ENABLE_METRICS=false

# Development/Debug Configuration
DEBUG=false
RELOAD=false
ENABLE_DOCS=true

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15

# Optional: Redis for caching (if implemented)
# REDIS_URL=redis://localhost:6379/0

# Optional: Email configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@yourcompany.com